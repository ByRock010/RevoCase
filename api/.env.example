# Database (use Session Pooler URL for Supabase, or local Postgres for Docker)
# Supabase: postgresql://postgres.PROJECT_REF:YOUR_PASSWORD@aws-1-REGION.pooler.supabase.com:5432/postgres
# Docker:   postgresql://postgres:postgres@db:5432/revocase
DATABASE_URL=postgresql://postgres:postgres@db:5432/revocase

# JWT
JWT_SECRET_KEY=your-secret-key-here
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# Admin credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Revo123456.

# OpenAI API Key (required for AI-powered company analysis)
OPENAI_API_KEY=your-openai-api-key-here

# CORS (frontend URL)
FRONTEND_URL=http://localhost:5173
